{
  "layer": "top",
  "position": "top",
  "reload_style_on_change": true,
  "modules-left": [
    "custom/launcher",
    "custom/sep0",
    "sway/workspaces",
    "custom/sep1",
    "custom/mediaplayer"
  ],
  "modules-center": [
    "cpu",
    "memory",
    "temperature",
    "custom/weather"
  ],
  "modules-right": [
    "custom/recorder",
    "tray",
    "custom/pacman",
    "custom/sep3",
    "group/pulse-group",
    "custom/sep4",
    "network",
    "custom/sep5",
    "clock"
  ],
  "sway/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "",
      "2": "",
      "3": "",
      "4": "",
      "5": "",
      "focused": "",
      "default": ""
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "custom/sep0": {
    "format": "",
    "tooltip": false
  },
  "custom/sep1": {
    "format": "",
    "tooltip": false
  },
  "custom/sep3": {
    "format": "",
    "tooltip": false
  },
  "custom/sep4": {
    "format": "",
    "tooltip": false
  },
  "custom/sep5": {
    "format": "",
    "tooltip": false
  },
  "tray": {
    "icon-size": 18,
    "spacing": 5
  },
  "clock": {
    "format": "{:%a, %d %b • <span font-weight='800'>%H:%M</span>}",
    "timezone": "Europe/Brussels",
    "smooth-scrolling-threshold": 4,
    "calendar": {
      "mode-mon-col": 2,
      "weeks-pos": "left",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#b6e3ff'><b>{}</b></span>",
        "weeks": "<span color='#ecd8ff'><b>{}</b></span>",
        "weekdays": "<span color='#80ccff'><b>{}</b></span>",
        "today": "<span color='#ffb77c' background='#363D46'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "tooltip-format": "<tt>{calendar}</tt>"
  },
  "cpu": {
    "format": "{usage}% <span font='12' rise='-1600'>󱤓</span>"
  },
  "memory": {
    "format": "{percentage}% <span font='12' rise='-1600'>󰗉</span>"
  },
  "temperature": {
    "critical-threshold": 85,
    "format": "{temperatureC}°C  <span font='12' rise='-1900'>󱩅</span>",
    "hwmon-path": "/sys/class/hwmon/hwmon5/temp1_input",
    "tooltip": false
  },
  "custom/weather": {
    "format": "{} <span font='14' rise='-800'></span>",
    "exec": "$XDG_CONFIG_HOME/waybar/modules/waybar-weather",
    "restart-interval": 60,
    "return-type": "json",
    "tooltip": true,
    "on-click": "",
    "on-click-right": ""
  },
  "network": {
    "format-wifi": "<span font='10' rise='900'></span>",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr}",
    "format-linked": "{ifname} (No IP) ",
    "format-disconnected": "",
    "format-alt": "{ifname} on {essid}: {ipaddr}/{cidr}",
    "on-click-right": "iwgtk",
    "tooltip": false
  },
  "group/pulse-group": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "drawer-child",
      "transition-left-to-right": false
    },
    "modules": [
      "pulseaudio",
      "pulseaudio/slider"
    ]
  },
  "pulseaudio": {
    "format": "{icon}",
    "format-alt": "{format_source}    <span rise='-800'>{volume}%</span>  {icon}",
    "format-bluetooth": "<span font='13'>󰂰</span>",
    "format-bluetooth-muted": "<span font='13'>󰂰</span>",
    "format-muted": " {format_source}",
    "format-source": "<span rise='-800'>{volume}%</span>  <span font='11' rise='-400'></span>",
    "format-source-muted": "<span font='11' color='#A2A2A2' rise='-400'>󰍭</span>",
    "format-icons": {
      "headphone": "<span font='12'>󰋋</span>",
      "default": [
        "<span font='12' rise='-800'>󰜟</span>"
      ]
    },
    "smooth-scrolling-threshold": 0.8,
    "tooltip": false,
    "on-click-right": "pavucontrol",
    "on-scroll-up": "pactl set-sink-volume 0 +5%",
    "on-scroll-down": "pactl set-sink-volume 0 -5%"
  },
  "pulseaudio/slider": {
    "min": 0,
    "max": 100,
    "orientation": "horizontal"
  },
  "custom/pacman": {
    "format": "<span rise='-700'>{}</span> {icon}",
    "return-type": "json",
    "format-icons": {
      "pending-updates": "updates",
      "updated": ""
    },
    "exec-if": "which waybar-updates",
    "exec": "waybar-updates"
  },
  "custom/mediaplayer": {
    "format": "{}<span color='#6e6d8e'>{alt}</span>",
    "return-type": "json",
    "max-length": 60,
    "escape": true,
    "on-click": "mediactl previous",
    "on-click-right": "mediactl next",
    "exec": "$XDG_CONFIG_HOME/waybar/modules/mediaplayer.py --players spotify,mpd 2> /dev/null" // Script in resources folder
  },
  "custom/launcher": {
    "format": "",
    "on-click": "tofi-drun | xargs swaymsg exec --",
    "on-click-right": "wlogout -b 5 -p layer-shell",
    "tooltip": false
  },
  "custom/recorder": {
    "format": "󰈈",
    "return-type": "json",
    "interval": 1,
    "exec": "echo '{\"class\": \"recording\"}'",
    "exec-if": "pgrep wf-recorder"
  }
}
